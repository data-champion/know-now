{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://know-now.dev/schemas/logging/v0.1.0/event-shape.json",
  "title": "know-now Log Event Shape v0.1.0",
  "description": "Schema for tracing-subscriber JSON events. Validated by cargo xtask logs validate.",
  "type": "object",
  "required": ["timestamp", "level", "target"],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp (volatile — never in generated/)."
    },
    "level": {
      "type": "string",
      "enum": ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"]
    },
    "target": {
      "type": "string",
      "description": "Rust module path of the event source."
    },
    "span": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Span name (e.g., stage name from Stage::ALL)."
        }
      }
    },
    "spans": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      }
    },
    "fields": {
      "type": "object",
      "description": "Structured fields attached to the event."
    }
  }
}
