-- Generated by know-now. Artifact ID: art_dbt_test_is_valid_email. Generator: know_now_gen_dbt. Version: [REDACTED].

{% test is_valid_email(model, column_name) %}

select
    {{ column_name }} as invalid_email
from {{ model }}
where {{ column_name }} is not null
  and {{ column_name }} not similar to '[^\s@]+@[^\s@]+\.[^\s@]+'

{% endtest %}
